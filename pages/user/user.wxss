page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  padding: 20px;
  padding-bottom: calc(90px + env(safe-area-inset-bottom));
}

.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}

.avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #f5f5f5;
}

.nickname {
  margin-top: 16px;
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.menu-list {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 15px;
  color: #333;
}

.menu-text.logout {
  color: #ff6b6b;
}

.menu-arrow {
  font-size: 14px;
  color: #999;
}
