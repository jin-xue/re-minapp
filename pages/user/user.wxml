<view class="container">
  <view class="user-header">
    <image class="avatar" src="{{userInfo.wxHeadImgUrl || '/resource/tab/home.png'}}" mode="aspectFill"></image>
    <text class="nickname">{{userInfo.name || userInfo.username}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onAboutUs">
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onLogout">
      <text class="menu-text logout">退出登录</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
