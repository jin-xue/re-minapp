page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  padding: 16px;
  padding-bottom: calc(90px + env(safe-area-inset-bottom));
}

.quick-actions {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
}

.time-filter {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 12px;
  background: #fff;
  margin-bottom: 16px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.time-picker-wrapper {
  flex: 1;
}

.time-picker {
  height: 36px;
  font-size: 14px;
  color: #333;
  padding: 0 8px;
  box-sizing: border-box;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.time-separator-wrapper {
  width: 30px;
  display: flex;
  justify-content: center;
}

.time-separator {
  color: #999;
  font-size: 14px;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}

.quick-options {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 16px 16px 0 0;
  z-index: 1000;
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -8px 24px rgba(0,0,0,0.12);
}

.quick-option {
  background: #fff;
  padding: 14px;
  text-align: center;
  font-size: 16px;
  color: #333;
  border-radius: 8px;
  margin-bottom: 8px;
}

.quick-option:last-child {
  margin-bottom: 0;
}

.action-btn {
  flex: 1;
  height: 80px;
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.5s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulseIn {
  0%, 100% {
    box-shadow: 0 4px 16px rgba(20, 127, 237, 0.35);
  }
  50% {
    box-shadow: 0 4px 24px rgba(20, 127, 237, 0.5);
  }
}

.action-btn:active {
  transform: scale(0.96);
}

.in-btn {
  background: linear-gradient(135deg, #147fed, #0ac261);
  box-shadow: 0 4px 16px rgba(20, 127, 237, 0.35);
  animation: fadeInUp 0.5s ease forwards, pulseIn 2s ease-in-out infinite 0.5s;
  opacity: 0;
  animation-delay: 0.1s;
}

.out-btn {
  background: linear-gradient(135deg, #ff6b6b, #ffa500);
  box-shadow: 0 4px 16px rgba(255, 107, 107, 0.35);
  animation: fadeInUp 0.5s ease forwards, pulseOut 2s ease-in-out infinite 0.5s;
  opacity: 0;
  animation-delay: 0.2s;
}

.action-icon {
  font-size: 28px;
  font-weight: bold;
  margin-bottom: 4px;
}

.action-text {
  font-size: 15px;
  font-weight: 500;
}

.action-text {
  font-size: 14px;
  margin-top: 4px;
}

.stats-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 16px;
}

.stat-card {
  width: calc(50% - 6px);
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.stat-label {
  font-size: 12px;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.stat-value {
  font-size: 20px;
  font-weight: bold;
  color: #333;
}

.stat-value.profit {
  color: #0ac261;
}

.recent-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.section-header {
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.record-list {
  height: 300px;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.record-type {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 10px;
  color: #fff;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.record-name {
  font-size: 13px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 11px;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.record-type {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  color: #fff;
}

.record-type.in {
  background: #0ac261;
}

.record-type.out {
  background: #ff6b6b;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 14px;
  color: #333;
}

.record-time {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.record-qty {
  font-size: 16px;
  font-weight: bold;
}

.record-qty.in {
  color: #0ac261;
}

.record-qty.out {
  color: #ff6b6b;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24px 24px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: 90px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 24px;
  color: #999;
  padding: 0 8px;
}

.modal-body {
  padding: 24px;
}

.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: #64748b;
  font-weight: 500;
  display: block;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
}

.picker-box {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
  display: flex;
  align-items: center;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: 10px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #147fed;
  color: #fff;
}

.modal-btn.confirm.out {
  background: #ff6b6b;
}
