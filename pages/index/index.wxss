page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  padding: 16px;
}

.quick-actions {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
}

.action-btn {
  flex: 1;
  height: 80px;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.in-btn {
  background: linear-gradient(135deg, #147fed, #0ac261);
}

.out-btn {
  background: linear-gradient(135deg, #ff6b6b, #ffa500);
}

.action-icon {
  font-size: 28px;
  font-weight: bold;
}

.action-text {
  font-size: 14px;
  margin-top: 4px;
}

.stats-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 16px;
}

.stat-card {
  width: calc(50% - 6px);
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.stat-label {
  font-size: 12px;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.stat-value {
  font-size: 20px;
  font-weight: bold;
  color: #333;
}

.stat-value.profit {
  color: #0ac261;
}

.recent-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.section-header {
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.record-list {
  height: 300px;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.record-type {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 10px;
  color: #fff;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.record-name {
  font-size: 13px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 11px;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.record-type {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  color: #fff;
}

.record-type.in {
  background: #0ac261;
}

.record-type.out {
  background: #ff6b6b;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 14px;
  color: #333;
}

.record-time {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.record-qty {
  font-size: 16px;
  font-weight: bold;
}

.record-qty.in {
  color: #0ac261;
}

.record-qty.out {
  color: #ff6b6b;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24px 24px 0 0;
  z-index: 101;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 24px;
  color: #999;
  padding: 0 8px;
}

.modal-body {
  padding: 24px;
}

.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: #64748b;
  font-weight: 500;
  display: block;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
}

.picker-box {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
  display: flex;
  align-items: center;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: 10px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #147fed;
  color: #fff;
}

.modal-btn.confirm.out {
  background: #ff6b6b;
}
