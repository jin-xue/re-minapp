/* pages/login/login.wxss */
page {
  height: 100%;
}

.toast {
  position: fixed;
  top: 30px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 10px 20px;
  border-radius: 5px;
  font-size: 12px;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 9999;
  white-space: nowrap;
}

.toast-show {
  opacity: 1;
}

.container{
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  margin: 0;
}

.banner{
  width: 100%;
  height: 100px;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 0;
}

.banner image {
  width: 120px;
  height: 120px;
  border-radius: 50%;
}

.form {
  width: 100%;
  padding: 0 40px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.form text{
  font-size: 11px;
  color: #64748b;
  font-weight: 500;
  margin-top: 1rem;
}
.form input {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 13px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
}

.input-wrap {
  position: relative;
  width: 100%;
  height: 44px;
  margin-top: 1rem;
}

.input-icon {
  position: absolute;
  top: 0;
  left: 10px;
  bottom: 0;
  right: 0;
  margin: auto 0;
  width: 13px;
  height: 13px;
}

.form .login-btn {
  width: 100%;
  height: 44px;
  background: #147fed;
  color: #fff;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  margin-top: 2rem;
}

.split {
  width: 100%;
  padding: 0 40px;
  box-sizing: border-box;
  margin-top: 2rem;
  display: flex;
  align-items: center;
  position: relative;
}

.split-line {
  position: absolute;
  left: 40px;
  right: 40px;
  height: 1px;
  background: #e5e5e5;
}

.split-text {
  margin: 0 auto;
  padding: 0 10px;
  background: #fff;
  color: #999;
  font-size: 12px;
  position: relative;
  z-index: 1;
}

.other-login{
  width: 100%;
  margin-top: 2rem;
  padding: 0 40px;
  box-sizing:border-box;

}

.other-login .phone-btn{
  width: 100%;
  height: 44px;
  background: #0ac261;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  color: #fff;

}