page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(90px + env(safe-area-inset-bottom) + 10px);
}

.filter-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  flex: 1;
}

.filter-input {
  width: 100%;
  height: 36px;
  border: 1px solid #fafafc;
  font-size: 14px;
  color: #000;
  border-radius: 8px;
  padding: 0 12px;
  box-sizing: border-box;
  background-color: #fafafc;
}

.filter-picker {
  width: 100%;
  height: 36px;
  border: 1px solid #fafafc;
  font-size: 14px;
  color: #999;
  border-radius: 8px;
  padding: 0 12px;
  box-sizing: border-box;
  background-color: #fafafc;
  display: flex;
  align-items: center;
}

.filter-btn {
  width: 50px;
  height: 36px;
  background: #147fed;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn.clear {
  background: #999;
}

.stock-list {
  flex: 1;
  height: 0;
  padding: 12px;
  box-sizing: border-box;
}

.stock-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.stock-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.header-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
}

.header-right {
  display: flex;
  gap: 8px;
  align-items: center;
}

.delete-btn {
  font-size: 12px;
  color: #ffffff;
  background: #ff6b6b;
  padding: 4px 12px;
  border-radius: 12px;
}

.edit-btn {
  font-size: 12px;
  color: #ffffff;
  background: #147fed;
  padding: 4px 12px;
  border-radius: 12px;
}

.header-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
}

.goods-img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  background: #f5f5f5;
}

.goods-img-placeholder {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  background: #f5f5f5;
}

.goods-basic {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.goods-code {
  font-size: 12px;
  color: #999;
}

.stock-details {
  margin-bottom: 8px;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.detail-tag {
  width: calc(33.33% - 6px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 10px;
  background: #f5f5f5;
  border-radius: 6px;
  box-sizing: border-box;
}

.tag-label {
  font-size: 11px;
  color: #999;
}

.tag-value {
  font-size: 12px;
  color: #333;
  font-weight: 500;
}

.tag-value.profit {
  color: #0ac261;
}

.stock-footer {
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.footer-text {
  font-size: 12px;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60px 0;
  color: #999;
  font-size: 14px;
}

.loading-tip {
  text-align: center;
  padding: 20px 0;
  color: #999;
  font-size: 12px;
}

/* 新建按钮 */
.add-btn {
  position: fixed;
  right: 20px;
  bottom: calc(40px + 50px + env(safe-area-inset-bottom));
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #147fed;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(20, 127, 237, 0.4);
  z-index: 99;
}

.add-icon {
  font-size: 32px;
  color: #fff;
  font-weight: 300;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24px 24px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: 90px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 24px;
  color: #999;
  padding: 0 8px;
}

.modal-body {
  padding: 24px;
}

.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: #64748b;
  font-weight: 500;
  display: block;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
}

.picker-box {
  width: 100%;
  height: 44px;
  border: 1px solid #fafafc;
  font-size: 15px;
  color: #000;
  border-radius: 10px;
  padding: 0 30px;
  box-sizing: border-box;
  background-color: #fafafc;
  display: flex;
  align-items: center;
  color: #999;
}

.img-upload {
  width: 80px;
  height: 80px;
  border: 1px dashed #d9d9d9;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.upload-icon {
  font-size: 24px;
  color: #999;
}

.upload-text {
  font-size: 12px;
  margin-top: 4px;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: 10px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #147fed;
  color: #fff;
}
